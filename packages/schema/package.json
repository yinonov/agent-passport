{
  "name": "@agent-passport/schema",
  "version": "0.1.0",
  "description": "TypeScript + Zod schemas for Agent Passport",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
